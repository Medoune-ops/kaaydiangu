generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Ecole {
  id                  String   @id @default(cuid())
  nom                 String
  logo                String?
  slogan              String?
  adresse             String?
  telephone           String?
  email               String?
  annee_scolaire      String
  frais_inscription   Float    @default(0)
  impaye_seuil_jours  Int      @default(30)
  impaye_liste_active Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users    User[]
  classes  Classe[]
  depenses Depense[]
}

enum Role {
  SUPER_ADMIN
  COMPTABLE
  CENSEUR
  PROFESSEUR
  ELEVE
}

model User {
  id           String   @id @default(cuid())
  nom          String
  prenom       String
  email        String   @unique
  mot_de_passe String
  role         Role
  actif        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ecole_id String
  ecole    Ecole  @relation(fields: [ecole_id], references: [id])

  eleve         Eleve?
  matieres      Matiere[]
  paiements     Paiement[]
  depenses      Depense[]
  cours         Cours[]
  appreciations Appreciation[]
  notifications Notification[]
  auditLogs     AuditLog[]
}

model Eleve {
  id               String    @id @default(cuid())
  matricule        String    @unique
  nom              String
  prenom           String
  date_naissance   DateTime?
  sexe             String?
  photo            String?
  adresse          String?
  telephone_parent String?
  email_parent     String?
  nom_parent       String?
  date_inscription DateTime  @default(now())
  actif            Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  classe_id String
  classe    Classe @relation(fields: [classe_id], references: [id])

  user_id String @unique
  user    User   @relation(fields: [user_id], references: [id])

  notes         Note[]
  absences      Absence[]
  paiements     Paiement[]
  appreciations Appreciation[]
}

model Classe {
  id                String   @id @default(cuid())
  nom               String
  niveau            String
  filiere           String?
  annee_scolaire    String
  montant_scolarite Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ecole_id String
  ecole    Ecole  @relation(fields: [ecole_id], references: [id])

  eleves         Eleve[]
  matieres       Matiere[]
  emploisDuTemps EmploiDuTemps[]
  cours          Cours[]
}

model Matiere {
  id          String   @id @default(cuid())
  nom         String
  coefficient Float    @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  classe_id String
  classe    Classe @relation(fields: [classe_id], references: [id])

  professeur_id String?
  professeur    User?   @relation(fields: [professeur_id], references: [id])

  notes          Note[]
  absences       Absence[]
  emploisDuTemps EmploiDuTemps[]
  cours          Cours[]
}

enum TypeNote {
  CONTROLE
  DEVOIR
  EXAMEN
}

model Note {
  id           String   @id @default(cuid())
  valeur       Float
  type         TypeNote
  date         DateTime @default(now())
  sequence     Int
  appreciation String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  eleve_id String
  eleve    Eleve  @relation(fields: [eleve_id], references: [id])

  matiere_id String
  matiere    Matiere @relation(fields: [matiere_id], references: [id])
}

model Appreciation {
  id        String   @id @default(cuid())
  texte     String
  sequence  Int
  createdAt DateTime @default(now())

  eleve_id String
  eleve    Eleve  @relation(fields: [eleve_id], references: [id])

  auteur_id String
  auteur    User   @relation(fields: [auteur_id], references: [id])
}

model Absence {
  id           String   @id @default(cuid())
  date         DateTime
  duree_heures Float
  justifiee    Boolean  @default(false)
  motif        String?
  createdAt    DateTime @default(now())

  eleve_id String
  eleve    Eleve  @relation(fields: [eleve_id], references: [id])

  matiere_id String
  matiere    Matiere @relation(fields: [matiere_id], references: [id])
}

enum Jour {
  LUNDI
  MARDI
  MERCREDI
  JEUDI
  VENDREDI
  SAMEDI
}

model EmploiDuTemps {
  id          String   @id @default(cuid())
  jour        Jour
  heure_debut String
  heure_fin   String
  salle       String?
  createdAt   DateTime @default(now())

  matiere_id String
  matiere    Matiere @relation(fields: [matiere_id], references: [id])

  classe_id String
  classe    Classe @relation(fields: [classe_id], references: [id])
}

enum ModePaiement {
  ESPECES
  MOBILE_MONEY
  VIREMENT
}

enum StatutPaiement {
  NON_PAYE
  PAYE
}

model Paiement {
  id            String          @id @default(cuid())
  mois          Int
  annee         Int
  montant       Float           @default(0)
  statut        StatutPaiement  @default(NON_PAYE)
  date_paiement DateTime?
  mode          ModePaiement?
  recu_numero   String?         @unique
  recu_url      String?
  createdAt     DateTime        @default(now())

  eleve_id String
  eleve    Eleve  @relation(fields: [eleve_id], references: [id])

  enregistre_par_id String?
  enregistre_par    User?  @relation(fields: [enregistre_par_id], references: [id])
}

enum CategorieDepense {
  SALAIRE
  FOURNITURE
  MAINTENANCE
  AUTRE
}

model Depense {
  id        String           @id @default(cuid())
  libelle   String
  montant   Float
  date      DateTime
  categorie CategorieDepense
  createdAt DateTime         @default(now())

  ecole_id String
  ecole    Ecole  @relation(fields: [ecole_id], references: [id])

  enregistre_par_id String
  enregistre_par    User   @relation(fields: [enregistre_par_id], references: [id])
}

model Cours {
  id          String   @id @default(cuid())
  titre       String
  description String?
  fichier_url String
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  matiere_id String
  matiere    Matiere @relation(fields: [matiere_id], references: [id])

  classe_id String
  classe    Classe @relation(fields: [classe_id], references: [id])

  depose_par_id String
  depose_par    User   @relation(fields: [depose_par_id], references: [id])
}

model Notification {
  id         String   @id @default(cuid())
  titre      String
  message    String
  lu         Boolean  @default(false)
  type       String?
  date_envoi DateTime @default(now())

  destinataire_id String
  destinataire    User   @relation(fields: [destinataire_id], references: [id])
}

model AuditLog {
  id      String   @id @default(cuid())
  action  String
  details Json?
  date    DateTime @default(now())

  auteur_id String
  auteur    User   @relation(fields: [auteur_id], references: [id])
}

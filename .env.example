# =============================================================================
# FICHIER D'EXEMPLE — NE CONTIENT PAS DE SECRETS RÉELS
# Copiez ce fichier en .env.local et remplissez avec vos vraies valeurs.
# Le fichier .env.local ne doit JAMAIS être commité dans git.
# =============================================================================

# -----------------------------------------------------------------------------
# Base de données Neon PostgreSQL
# Créez votre base sur https://console.neon.tech
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&channel_binding=require"

# -----------------------------------------------------------------------------
# NextAuth v5 — Authentification
# Générez un secret fort avec : openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET="VOTRE_SECRET_ICI_MINIMUM_32_CARACTERES"

# -----------------------------------------------------------------------------
# URL de l'application
#
# DÉVELOPPEMENT LOCAL :
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
#
# PRODUCTION (à configurer dans Vercel / votre hébergeur, PAS ici) :
# NEXTAUTH_URL="https://votre-domaine.com"
# NEXT_PUBLIC_APP_URL="https://votre-domaine.com"
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Cloudinary — Upload et gestion des photos
# Créez un compte sur https://cloudinary.com
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME="votre-cloud-name"
CLOUDINARY_API_KEY="votre-api-key"
CLOUDINARY_API_SECRET="votre-api-secret"

# -----------------------------------------------------------------------------
# Resend — Envoi d'emails transactionnels
# Créez un compte sur https://resend.com
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_votre_cle_ici"
